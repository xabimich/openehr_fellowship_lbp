        <inputEntry id="inputEntry_ie_drug_iv_1">
          <text><![CDATA[-]]></text>
        </inputEntry>
        <inputEntry id="inputEntry_ie_age_alert_1">
          <text><![CDATA[-]]></text>
        </inputEntry>
        <outputEntry id="outputEntry_out_redFlagDestination_1">
          <text><![CDATA["urgencies"]]></text>
        </outputEntry>
      </rule>
