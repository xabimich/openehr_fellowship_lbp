    <textAnnotation id="TextAnnotation_46">
      <extensionElements>
        <design:stencilid><![CDATA[TextAnnotation]]></design:stencilid>
        <design:text><![CDATA[IN: processDefinition-> Identifies the Business Process and also the entity within the Administrative Composition
IN: idEHR-> OpenEHR patient identifier
IN: idComposition-> Id Composition Reason for Encounter
IN: pathFolderProcesoClinicio-> Identifies the Clinical Process Folder
IN: pathCompositionAdministrative-> Identifies the Administrative Composition of the indicated Type
IN: CompositionAdministrativeType-> Identifies, for administrative compositions, the type of Clinical Process
IN: FolderType-> Identifies, for Clinical Process Folders, the type of Clinical Process

OUT: idInstanciaProceso-> Business Process Identifier]]></design:text>
      </extensionElements>
      <text>IN: processDefinition-&gt; Identifies the Business Process and also the entity within the Administrative Composition
IN: idEHR-&gt; OpenEHR patient identifier
IN: idComposition-&gt; Id Composition Reason for Encounter
IN: pathFolderProcesoClinicio-&gt; Identifies the Clinical Process Folder
IN: pathCompositionAdministrative-&gt; Identifies the Administrative Composition of the indicated Type
IN: CompositionAdministrativeType-&gt; Identifies, for administrative compositions, the type of Clinical Process
IN: FolderType-&gt; Identifies, for Clinical Process Folders, the type of Clinical Process

OUT: idInstanciaProceso-&gt; Business Process Identifier</text>
    </textAnnotation>
    <textAnnotation id="TextAnnotation_63">
      <extensionElements>
        <design:stencilid><![CDATA[TextAnnotation]]></design:stencilid>
        <design:text><![CDATA[IN: pathFolderProcesoClinicio-> Identifies the Clinical Process Folder
IN: pathCompositionTask: Indicates the composition where the data related to the Task has been saved
IN: versionCompositionTask: version of the composition where the data related to the Task is stored specifically]]></design:text>
      </extensionElements>
      <text>IN: pathFolderProcesoClinicio-&gt; Identifies the Clinical Process Folder
IN: pathCompositionTask: Indicates the composition where the data related to the Task has been saved
IN: versionCompositionTask: version of the composition where the data related to the Task is stored specifically</text>
    </textAnnotation>
    <textAnnotation id="TextAnnotation_58">
      <extensionElements>
        <design:stencilid><![CDATA[TextAnnotation]]></design:stencilid>
        <design:text><![CDATA[IN: template-> Identifies the Template of the Composition to be saved
IN: archetypes -> archetypes of the Template to Manage

OUT: pathCompositionTask: Indicates the composition where the data related to the Task has been saved
OUT: versionCompositionTask: version of the composition where the data related to the Task is stored specifically]]></design:text>
      </extensionElements>
      <text>IN: template-&gt; Identifies the Template of the Composition to be saved
IN: archetypes -&gt; archetypes of the Template to Manage

OUT: pathCompositionTask: Indicates the composition where the data related to the Task has been saved
OUT: versionCompositionTask: version of the composition where the data related to the Task is stored specifically</text>
    </textAnnotation>
    <textAnnotation id="TextAnnotation_14">
      <extensionElements>
        <design:stencilid><![CDATA[TextAnnotation]]></design:stencilid>
        <design:text><![CDATA[IN: pathCompositionAdministrative-> Identifies the Administrative Composition of the indicated Type
IN: processDefinition-> Identifies the Business Process and also the entity within the Administrative Composition
IN: idInstanciaProceso-> Business Process Identifier corresponding to the Process Definition within the Administrative Composition of the indicated Type
IN: Phase=Follow-up -> Identifies the Follow-up phase]]></design:text>
      </extensionElements>
      <text>IN: pathCompositionAdministrative-&gt; Identifies the Administrative Composition of the indicated Type
IN: processDefinition-&gt; Identifies the Business Process and also the entity within the Administrative Composition
IN: idInstanciaProceso-&gt; Business Process Identifier corresponding to the Process Definition within the Administrative Composition of the indicated Type
IN: Phase=Follow-up -&gt; Identifies the Follow-up phase</text>
    </textAnnotation>
