<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/" xmlns:flowable="http://flowable.org/dmn" xmlns:design="http://flowable.org/design" id="definition_yellowflags_routing1" name="Routing Yellow Flags Lumbalgia GPC ICS" namespace="http://www.flowable.org/dmn">
  <decision id="yellowflags_routing1" name="Routing Yellow Flags Lumbalgia GPC ICS">
    <description>PROPOSAL pending clinical validation. Evaluates the psychosocial risk factors for chronification (Yellow Flags) captured in the Lumbalgia_Checklist_CD_v0.3 template and decides the intervention according to GPC ICS Low Back Pain and international evidence (NICE, STarT Ba...</description>
    <decisionTable id="decisionTable_yellowflags_routing1" hitPolicy="FIRST">
      <input label="STarT Back high risk (score &gt;=4 with psychosocial subscale &gt;=4)">
        <inputExpression id="inputExpression_ie_startback_high" typeRef="boolean">
          <text>yf_startback_high_risk</text>
        </inputExpression>
      </input>
      <input label="Pain catastrophising (PCS &gt;=30 or positive self-report)">
        <inputExpression id="inputExpression_ie_pain_catastrophising" typeRef="boolean">
          <text>yf_pain_catastrophising</text>
        </inputExpression>
      </input>
      <input label="Kinesiophobia or fear of movement (FABQ &gt;=29 or positive self-report)">
        <inputExpression id="inputExpression_ie_kinesiophobia" typeRef="boolean">
          <text>yf_kinesiophobia</text>
        </inputExpression>
      </input>
      <input label="Low mood or depression (PHQ-2/PHQ-9 positive)">
        <inputExpression id="inputExpression_ie_low_mood" typeRef="boolean">
          <text>yf_low_mood_depression</text>
        </inputExpression>
      </input>
      <input label="Negative recovery expectations">
        <inputExpression id="inputExpression_ie_neg_expectations" typeRef="boolean">
          <text>yf_negative_recovery_expectations</text>
        </inputExpression>
      </input>
      <input label="Work dissatisfaction or conflict, prolonged sick leave">
        <inputExpression id="inputExpression_ie_work_issues" typeRef="boolean">
          <text>yf_work_dissatisfaction_or_conflict</text>
        </inputExpression>
      </input>
      <input label="Low social or family support">
        <inputExpression id="inputExpression_ie_low_support" typeRef="boolean">
          <text>yf_low_social_support</text>
        </inputExpression>
      </input>
      <input label="Low physical activity and sedentary behaviour">
        <inputExpression id="inputExpression_ie_low_activity" typeRef="boolean">
          <text>yf_low_physical_activity</text>
        </inputExpression>
      </input>
      <input label="High pain intensity (VAS &gt;=7/10) in patient questionnaire">
        <inputExpression id="inputExpression_ie_high_pain_intensity" typeRef="boolean">
          <text>yf_high_pain_intensity</text>
        </inputExpression>
      </input>
      <output id="outputExpression_out_yellowFlagDestination" label="Yellow Flags Intervention Destination" name="yellowFlagDestination" typeRef="string"></output>
      <rule>
        <inputEntry id="inputEntry_ie_startback_high_1">
          <text><![CDATA[true]]></text>
        </inputEntry>
        <inputEntry id="inputEntry_ie_pain_catastrophising_1">
          <text><![CDATA[-]]></text>
        </inputEntry>
        <inputEntry id="inputEntry_ie_kinesiophobia_1">
          <text><![CDATA[-]]></text>
        </inputEntry>
        <inputEntry id="inputEntry_ie_low_mood_1">
